# .env.example
# Copy this file to .env and fill in your values before running locally.
# For Streamlit Cloud, set these in the Secrets panel instead.
# For GitHub Actions, set them as repository Secrets.

# ---------------------------------------------------------------------------
# MONDAY.COM
# ---------------------------------------------------------------------------

# API token (Personal or service account token from monday.com > Admin > API)
MONDAY_KEY=your_monday_api_token_here

# Board ID (visible in the board URL: monday.com/boards/<BOARD_ID>)
MONDAY_BOARD_ID=your_board_id_here

# Column IDs (find them in monday.com > Board Settings > Columns, or via API)
MONDAY_COL_PROJECTS=board_relation_XXXXX
MONDAY_COL_TIME_TRACKING=duration_XXXXX
MONDAY_COL_PEOPLE=multiple_person_XXXXX
MONDAY_COL_STATUS=color_XXXXX
MONDAY_COL_PRIORITY=color_YYYYY
MONDAY_COL_EST_DURATION=numeric_XXXXX
MONDAY_COL_TIMELINE=timerange_XXXXX
MONDAY_COL_MODULE=dropdown_XXXXX
MONDAY_COL_SPECIALTY=dropdown_YYYYY
MONDAY_COL_COMMENTS=long_text_XXXXX

# ---------------------------------------------------------------------------
# GOOGLE SHEETS
# ---------------------------------------------------------------------------

# Spreadsheet ID (from the sheet URL: docs.google.com/spreadsheets/d/<ID>)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Service account credentials JSON as a single-line string
# Generate at: console.cloud.google.com > IAM > Service Accounts > Keys
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ---------------------------------------------------------------------------
# DASHBOARD DISPLAY
# ---------------------------------------------------------------------------

# Comma-separated list of responsible names to pre-select in sidebar filters
# Must match exactly how names appear in your Monday.com board
DEFAULT_RESPONSABLES=Alice Smith,Bob Jones,Carol White

# Comma-separated list of project names in priority order (top = highest)
# Used for hierarchical task sorting in the main dashboard
PROJECT_PRIORITY_ORDER=Project Alpha,Project Beta,Project Gamma

# Comma-separated list of team members tracked in the Hours vs Target section
# Must match exactly how names appear in your Monday.com board
HOURS_COHORT=Alice Smith,Bob Jones,Carol White,Dan Brown
